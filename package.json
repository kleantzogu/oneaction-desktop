{
  "name": "oneaction-desktop",
  "version": "0.2.1",
  "private": true,
  "description": "Oneaction desktop app (Electron shell)",
  "author": "Kleant Zogu <kzogu@ritech.co>",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc --watch",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac",
    "package:mac:notarized": "node scripts/verify-mac-notarization-env.js && npm run package:mac",
    "package:linux": "npm run build && electron-builder --linux",
    "test": "tsc -p tsconfig.test.json && node --test dist-test"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  },
  "build": {
    "appId": "app.oneaction.desktop",
    "productName": "Oneaction",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "publish": {
      "provider": "github",
      "owner": "kleantzogu",
      "repo": "oneaction-desktop"
    },
    "files": [
      "dist/**/*",
      "build/tray-icon.png",
      "build/tray-icon@2x.png",
      "package.json"
    ],
    "protocols": [
      {
        "name": "Oneaction",
        "schemes": [
          "oneaction"
        ],
        "role": "Viewer"
      }
    ],
    "fileAssociations": [
      {
        "ext": "pdf",
        "name": "PDF Document",
        "description": "PDF document",
        "mimeType": "application/pdf",
        "role": "Viewer"
      },
      {
        "ext": "epub",
        "name": "EPUB eBook",
        "description": "EPUB eBook",
        "mimeType": "application/epub+zip",
        "role": "Viewer"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/oneaction.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": true,
      "extendInfo": {
        "NSAppleEventsUsageDescription": "Oneaction needs to read the URL of your active browser tab to capture it into your inbox when you press Cmd+Shift+S."
      }
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "Office"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
